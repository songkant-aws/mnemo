#!/usr/bin/env python3
"""Queue a rich session breadcrumb on Stop.

This hook stores the full hook payload so later automation can extract or
re-extract memory without depending on a lossy preview string.
"""

from __future__ import annotations

import json
import os
import sys
from datetime import datetime
from pathlib import Path


CONFIG_PATH = Path(os.environ.get("MNEMO_CONFIG", str(Path.home() / ".mnemo" / "config.json")))
DEFAULT_VAULT = Path.home() / ".mnemo" / "vault"


def load_vault() -> Path:
    try:
        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
        return Path(data.get("vault_dir", str(DEFAULT_VAULT))).expanduser().resolve()
    except Exception:
        return DEFAULT_VAULT


def main() -> None:
    event = sys.argv[1].lower() if len(sys.argv) > 1 else ""
    if event != "stop":
        return

    vault = load_vault()
    queue_dir = vault / "queue"
    enabled_flag = queue_dir / ".auto-capture-enabled"
    if not enabled_flag.exists():
        return

    try:
        payload = json.load(sys.stdin)
    except Exception:
        return

    session_id = payload.get("session_id", "unknown")
    queue_dir.mkdir(parents=True, exist_ok=True)
    path = queue_dir / f"{datetime.now().strftime('%Y%m%d-%H%M%S')}-{session_id[:12]}.json"
    breadcrumb = {
        "captured_at": datetime.utcnow().isoformat() + "Z",
        "session_id": session_id,
        "stop_reason": payload.get("stop_reason", ""),
        "payload": payload,
    }
    path.write_text(json.dumps(breadcrumb, indent=2, sort_keys=True) + "\n", encoding="utf-8")


if __name__ == "__main__":
    main()
